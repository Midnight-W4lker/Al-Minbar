# Al-Minbar Environment Variables
# Copy this file to .env.local and fill in the required values

# Ollama Configuration (local AI - no API key needed)
# Install Ollama: https://ollama.ai
# Pull the model: ollama pull kimi-k2.5:cloud
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=kimi-k2.5:cloud

# Optional: API Base URLs (defaults provided in code)
# VITE_QURAN_API_BASE=https://api.alquran.cloud/v1
# VITE_ALADHAN_API_BASE=https://api.aladhan.com/v1
# VITE_MOSQUES_API_BASE=https://api.mosques.app/v1
# VITE_HADITH_API_BASE=https://api.hadith.gading.dev
#$2y$10$W9XAevrtL22ISk2imvA5OD46g0oPWJIIZFg9KSMocpuuJaybek2           ##Alternative: https://hadithapi.com

# Optional: Firebase (for authentication and cross-device sync)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Optional: Google Maps (for Masjid Finder map view)
# VITE_GOOGLE_MAPS_API_KEY=

# Optional: Error tracking with Sentry
# VITE_SENTRY_DSN=

# Optional: Analytics
# VITE_ANALYTICS_ID=
